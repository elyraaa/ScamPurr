# ─────────────────────────────────────────────────
# ScamPurr AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
# For local dev, SQLite is used by default (USE_SQLITE=true).
# For production (Neon PostgreSQL), set USE_SQLITE=false and provide DATABASE_URL.
USE_SQLITE=true
DATABASE_URL=sqlite:///./scampurr.db
# DATABASE_URL=postgresql+psycopg2://user:password@host/dbname  # Neon Postgres

# ── Firebase Authentication ────────────────────────
# Set FIREBASE_MOCK_AUTH=true to bypass Firebase verification in local dev.
# In production, set FIREBASE_MOCK_AUTH=false and provide credentials.
FIREBASE_MOCK_AUTH=true
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to your Firebase service account JSON key file
# FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── External APIs (Optional for MVP) ──────────────
# Leave empty to use mock services. The app works fully without these.
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# ── ML Service ────────────────────────────────────
# USE_MOCK_ML=true uses fast keyword-based scoring (no model file needed).
# Set to false and run scripts/train_model.py to use the Random Forest classifier.
USE_MOCK_ML=true
MODEL_PATH=model/scam_classifier.pkl

# ── URL Analysis Service ──────────────────────────
# USE_MOCK_URL=true uses pattern-based URL scoring (no external API calls).
USE_MOCK_URL=true

# ── App Settings ──────────────────────────────────
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
