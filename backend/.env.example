# ScamPurr AI backend environment variables.
# Copy this file to .env for local development.

# Database
# Local development uses SQLite by default.
# Production on Render should use Neon PostgreSQL with USE_SQLITE=false.
USE_SQLITE=true
DATABASE_URL=sqlite:///./scampurr.db
# DATABASE_URL=postgresql+psycopg2://user:password@host/dbname

# Authentication
# Local development can use placeholder email tokens from the frontend.
# Production must be false and must provide Firebase Admin credentials.
FIREBASE_MOCK_AUTH=true
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# External APIs
# Leave empty to use pattern-based checks where supported.
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# ML service
# USE_MOCK_ML=true uses fast keyword-based scoring.
# Set false after training backend/model/scam_classifier.pkl.
USE_MOCK_ML=true
MODEL_PATH=model/scam_classifier.pkl

# URL analysis service
# USE_MOCK_URL=true uses pattern-based URL scoring without external API calls.
USE_MOCK_URL=true

# App settings
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
